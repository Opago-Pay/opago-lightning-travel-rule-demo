# =============================================================================
# opago-MiCA-reference — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
.env/

# Environment files (real secrets – never commit)
.env
.env.local
.env.*.local
!.env.example

# Distribution / build artefacts
dist/
build/
*.egg-info/
*.egg
.eggs/
*.whl
node_modules/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
.pytest_cache/
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff cache
.ruff_cache/

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# SQLite databases (local dev only)
*.db
*.sqlite
data/

# Logs
*.log
logs/
.playwright-cli/

# Docker overrides
docker-compose.override.yml

# Generated at runtime by start_test_transaction.sh
frontend/config.json


#Ignore cursor AI rules
.cursor/rules/codacy.mdc
.cursor/rules/review-tooling.mdc
.demo-state/
