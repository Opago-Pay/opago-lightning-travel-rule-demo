# =============================================================================
# opago-MiCA-reference — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running.
#
#   cp .env.example .env
#
# All variables are loaded and validated at startup by pydantic-settings.
# Missing required variables will cause a ValidationError with a clear message.
# =============================================================================


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

# Application environment. Controls default log formatting and simulation mode.
# Values: development | test | production
APP_ENV=development


# -----------------------------------------------------------------------------
# Spark / Lightning Network
# (env prefix: SPARK_)
# -----------------------------------------------------------------------------

# Optional BIP-39 mnemonic phrase for the sender Spark wallet (12 or 24 words).
# If omitted, the sender wallet can generate a fresh mnemonic at runtime.
# SENDER_SPARK_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Optional alternative to SENDER_SPARK_MNEMONIC: raw seed/master key.
# SENDER_SPARK_MASTER_KEY=

# Optional BIP-39 mnemonic phrase for the receiver Spark wallet (12 or 24 words).
# RECEIVER_SPARK_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Optional alternative to RECEIVER_SPARK_MNEMONIC: raw seed/master key.
# RECEIVER_SPARK_MASTER_KEY=

# Bitcoin network to connect to through Spark.
# Values: MAINNET | REGTEST | SIGNET
SPARK_NETWORK=REGTEST


# -----------------------------------------------------------------------------
# VASP Identity & UMA Protocol
# (env prefix: VASP_)
# -----------------------------------------------------------------------------

# Public domain of this VASP. Used to construct UMA addresses and discovery
# endpoints (e.g. $user@vasp.example.com). Required.
VASP_DOMAIN=localhost

# PEM-encoded PKCS#8 EC P-256 private key used to sign UMA pay requests (JWS).
# Generate with: openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256
# Required.
UMA_SIGNING_KEY=

# PEM-encoded PKCS#8 EC P-256 private key used for JWE payload encryption
# (ECDH-ES+A256KW). Used to decrypt inbound IVMS101 payloads. Required.
UMA_ENCRYPTION_KEY=

# Legal name of this VASP organisation (used in IVMS101 originating VASP data).
# VASP_LEGAL_NAME=opago GmbH

# 20-character Legal Entity Identifier (LEI) of this VASP. Optional but
# strongly recommended for B2B and cross-border compliance.
# VASP_LEI_CODE=

# ISO 3166-1 alpha-2 country code for the VASP's jurisdiction.
VASP_JURISDICTION=DE

# UMA protocol version to advertise in discovery documents.
UMA_VERSION=1.0

# EUR amount threshold above which this deployment requires travel-rule handling.
TRAVEL_RULE_THRESHOLD_EUR=1000


# -----------------------------------------------------------------------------
# HTTP Server
# -----------------------------------------------------------------------------

# TCP port the FastAPI application listens on.
# In the dual-VASP demo: Sending VASP uses 3001, Receiving VASP uses 3002.
PORT=3000

# Network interface to bind. Use 0.0.0.0 to accept all connections.
HOST=0.0.0.0

# Publicly reachable base URL of this service. Used for self-referential URLs
# in UMA responses and travel rule callbacks. Must start with http:// or https://.
# Leave blank for local development.
# BASE_URL=https://vasp.example.com


# -----------------------------------------------------------------------------
# eIDAS 2.0 Wallet Integration
# (env prefix: EIDAS_)
# -----------------------------------------------------------------------------

# Enable the EU Digital Identity Wallet bridge (EIDASWalletBridge).
# When true, EIDAS_ISSUER_URL is required.
# eIDAS signing is only triggered when the receiving VASP explicitly requests
# it AND the user grants explicit consent.
EIDAS_ENABLED=false

# URL of the eIDAS-compliant OpenID4VP credential issuer / wallet provider.
# Required when EIDAS_ENABLED=true.
# EIDAS_ISSUER_URL=https://wallet.example.eu

# Optional identifier for the specific eIDAS wallet instance.
# EIDAS_WALLET_ID=


# -----------------------------------------------------------------------------
# Observability & Logging
# -----------------------------------------------------------------------------

# structlog minimum log level.
# Values: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Emit structured JSON logs. Automatically enabled when APP_ENV=production.
# Values: true | false
JSON_LOGS=false

# Optional OpenTelemetry OTLP collector endpoint for distributed tracing.
# Leave blank to disable OpenTelemetry export.
# OTEL_ENDPOINT=http://otel-collector:4318


# -----------------------------------------------------------------------------
# Database / Persistence
# (used for audit logs and compliance transfer records)
# -----------------------------------------------------------------------------

# Database connection string.
# SQLite (default): sqlite:./data/opago-mica.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite:./data/opago-mica.db

# Maximum number of database connections (relevant for PostgreSQL pools).
DATABASE_MAX_CONNECTIONS=5
